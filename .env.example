# PeerLens configuration
PEERLENS_ENV=development
PEERLENS_HOST=0.0.0.0
PEERLENS_PORT=8000
PEERLENS_LOG_LEVEL=info

# Comma-separated origins for CORS (frontend dev server)
# PEERLENS_CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# Required for live RAG Q&A (embeddings + answers). Omit on public demo deploys.
# OPENAI_API_KEY=sk-...

# Public demo: static chat responses, no OpenAI calls (also auto-enabled when no API key)
PEERLENS_RAG_DEMO_MODE=true

# Optional custom demo message
# PEERLENS_RAG_DEMO_MESSAGE=This is a demo — LLM responses are disabled.

# Optional overrides
# PEERLENS_LLM_MODEL=gpt-4o-mini
# PEERLENS_EMBEDDING_MODEL=text-embedding-3-small
# PEERLENS_OPENAI_BASE_URL=https://api.openai.com/v1
